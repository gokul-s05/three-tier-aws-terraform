# Local .terraform directories
**/.terraform/*

# Terraform lock file (optional - many teams commit this, up to you)
# .terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files if they contain sensitive data
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# State files - NEVER commit these, they can contain secrets
*.tfstate
*.tfstate.*
